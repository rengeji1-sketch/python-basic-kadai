        "def culculate_tax_amount(price, tax_rate):\n",
        "  tax_amount = price * tax_rate / 100\n",
        "\n",
        "  total = price + tax_amount\n",
        "\n",
        "  return total\n",
        "\n",
        "culculate_tax_amount(110, 10)\n"
